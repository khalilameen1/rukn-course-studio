ENVIRONMENT=development
DATABASE_URL=sqlite:///./rukn_course_studio.db

# Which AIProvider the orchestrator uses (see app/ai/factory.py):
#   fake      - deterministic placeholder content, no API calls, no key needed (default).
#   anthropic - real Claude calls; also requires ANTHROPIC_API_KEY and AI_MODEL_NAME below.
AI_PROVIDER=fake

# Required only when AI_PROVIDER=anthropic. Leave blank while using fake.
ANTHROPIC_API_KEY=
AI_MODEL_NAME=

# Single-admin-user auth (see app/auth/) - no multi-user accounts,
# registration, roles, or OAuth. AUTH_ENABLED defaults to true, so set all
# three of these or login/every protected route will fail with a clear
# 401/503 instead of silently allowing access.
AUTH_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
AUTH_SECRET_KEY=change-me-too
