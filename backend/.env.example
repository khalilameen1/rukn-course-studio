ENVIRONMENT=development
DATABASE_URL=sqlite:///./rukn_course_studio.db

# Which AIProvider the orchestrator uses (see app/ai/factory.py):
#   fake      - deterministic placeholder content, no API calls, no key needed (default).
#   anthropic - real Claude calls; also requires ANTHROPIC_API_KEY and AI_MODEL_NAME below.
AI_PROVIDER=fake

# Required only when AI_PROVIDER=anthropic. Leave blank while using fake.
ANTHROPIC_API_KEY=
AI_MODEL_NAME=
