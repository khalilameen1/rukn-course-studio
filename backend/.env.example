ENVIRONMENT=development

# Leave both DATABASE_URL and SQLITE_DB_PATH unset for local dev - the app
# then defaults to a local SQLite file under backend/ automatically (see
# app/config.py `_resolve_database_url`).
#
# In production (Render), set DATABASE_URL to a Postgres connection string
# (e.g. Render Postgres' "Internal Database URL") - this always takes
# priority over SQLITE_DB_PATH below. Never commit a real value here.
# DATABASE_URL=postgresql://user:password@host/dbname

# Legacy/temporary fallback: only used when DATABASE_URL is unset. Set this
# instead of DATABASE_URL to keep using SQLite in production, pointed at an
# absolute path on a persistent disk - simpler than hand-building a
# sqlite:// URL. See the "Deploying to Render" section of README.md.
# SQLITE_DB_PATH=/opt/render/project/src/backend/storage/rukn_course_studio.db

# Which AIProvider the orchestrator uses (see app/ai/factory.py):
#   fake   - deterministic placeholder content, no API calls (tests/local smoke).
#   openai - production OpenAI Responses API generation.
AI_PROVIDER=fake

# Production values. Never commit a real key.
OPENAI_API_KEY=
AI_MODEL_NAME=gpt-5.6-sol
# Pro+max map/final stages can legitimately take several minutes.
OPENAI_REQUEST_TIMEOUT_SECONDS=1800

# Single-admin-user auth (see app/auth/) - no multi-user accounts,
# registration, roles, or OAuth. AUTH_ENABLED defaults to true, so set all
# three of these or login/every protected route will fail with a clear
# 401/503 instead of silently allowing access.
AUTH_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
AUTH_SECRET_KEY=change-me-too

# Leave unset for local dev (defaults to backend/../storage). In production,
# point this at the persistent disk mount so uploaded sources and generated
# DOCX files survive redeploys - independent of where the database lives.
# STORAGE_DIR=/opt/render/project/src/backend/storage

# Optional convenience: allow exactly one extra frontend origin for CORS
# without hand-writing a CORS_ORIGINS JSON array. Leave unset locally
# (defaults already include http://localhost:3000). In production on Render,
# set this to the frontend origin ONLY — https, no trailing slash, no /health:
# FRONTEND_ORIGIN=https://your-frontend.onrender.com
